# Copy to .env (gitignored) and fill in real values.
# docker-compose.yml passes these through to the container; mockingbird.yaml
# references them as ${KAFKA_USERNAME} / ${KAFKA_PASSWORD}.
#
# Add more of your own the same way: name it here, pass it through in
# docker-compose.yml's `environment:` block, reference it as ${VAR} in
# mockingbird.yaml.

KAFKA_USERNAME=
KAFKA_PASSWORD=
